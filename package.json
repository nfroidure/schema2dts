{
  "metapak": {
    "configs": [
      "main",
      "tsesm",
      "jest",
      "readme",
      "eslint",
      "ghactions",
      "jsdocs"
    ],
    "data": {
      "files": "'src/**/*.ts'",
      "testFiles": "'src/**/*.test.ts'",
      "distFiles": "'dist/**/*.js'",
      "ignore": [
        "dist"
      ],
      "bundleFiles": [
        "dist",
        "src"
      ]
    }
  },
  "name": "schema2dts",
  "version": "9.0.1",
  "description": "A very simple JSONSchema7/OpenAPI3 to TypeScript types definitions generator",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "tags": [
    "jsonschema",
    "openapi",
    "openapi3",
    "typescript",
    "dts",
    "types"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/nfroidure/schema2dts.git"
  },
  "scripts": {
    "build": "rimraf 'dist' && tsc --outDir dist",
    "changelog": "conventional-changelog -p angular -i CHANGELOG.md -s && git add CHANGELOG.md",
    "cli": "env NODE_ENV=${NODE_ENV:-cli}",
    "commitlint": "commitlint",
    "cover": "node --run jest -- --coverage",
    "doc": "echo \"# API\" > API.md; jsdoc2md 'dist/**/*.js' >> API.md && git add API.md",
    "format": "node --run prettier",
    "jest": "NODE_OPTIONS=--experimental-vm-modules NODE_ENV=test jest",
    "lint": "eslint 'src/**/*.ts'",
    "metapak": "metapak",
    "precommit": "node --run test && node --run lint && node --run metapak -- -s && node --run build && node --run doc",
    "prettier": "prettier --write 'src/**/*.ts'",
    "preversion": "node --run build && node --run lint && node --run test && node --run metapak -- -s && node --run doc",
    "rebuild": "swc ./src -s -d dist -C jsc.target=es2022",
    "test": "node --run jest",
    "version": "node --run changelog"
  },
  "author": {
    "name": "Nicolas Froidure",
    "email": "nicolas.froidure@insertafter.com",
    "url": "https://insertafter.com/en/index.html"
  },
  "license": "ISC",
  "dependencies": {
    "@types/debug": "^4.1.13",
    "application-services": "^9.0.1",
    "camelcase": "^9.0.0",
    "common-services": "^20.0.0",
    "debug": "^4.4.3",
    "knifecycle": "^21.1.0",
    "type-fest": "^5.6.0",
    "typescript": "^6.0.2",
    "ya-json-schema-types": "^2.0.2",
    "ya-open-api-types": "^2.2.0",
    "yerror": "^11.0.0"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.0",
    "@eslint/js": "^10.0.1",
    "@swc/cli": "^0.8.1",
    "@swc/core": "^1.15.24",
    "@swc/jest": "^0.2.39",
    "conventional-changelog": "^7.2.0",
    "eslint": "^10.2.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-jest": "^29.15.1",
    "eslint-plugin-prettier": "^5.5.5",
    "jest": "^30.3.0",
    "jsdoc-to-markdown": "^9.1.3",
    "metapak": "^7.1.1",
    "metapak-nfroidure": "22.1.1",
    "prettier": "^3.8.1",
    "rimraf": "^6.1.3",
    "typescript": "^6.0.2",
    "typescript-eslint": "^8.58.0"
  },
  "contributors": [],
  "engines": {
    "node": ">=24.14.0"
  },
  "files": [
    "dist",
    "src",
    "LICENSE",
    "README.md",
    "CHANGELOG.md"
  ],
  "bugs": {
    "url": "https://github.com/nfroidure/schema2dts/issues"
  },
  "homepage": "https://github.com/nfroidure/schema2dts#readme",
  "jest": {
    "coverageReporters": [
      "lcov"
    ],
    "testPathIgnorePatterns": [
      "/node_modules/"
    ],
    "roots": [
      "<rootDir>/src"
    ],
    "transform": {
      "^.+\\.tsx?$": [
        "@swc/jest",
        {}
      ]
    },
    "testEnvironment": "node",
    "moduleNameMapper": {
      "(.+)\\.js": "$1"
    },
    "extensionsToTreatAsEsm": [
      ".ts"
    ]
  },
  "prettier": {
    "semi": true,
    "printWidth": 80,
    "singleQuote": true,
    "trailingComma": "all",
    "proseWrap": "always"
  },
  "funding": {
    "type": "individual",
    "url": "https://github.com/sponsors/nfroidure"
  },
  "overrides": {
    "typescript-eslint": {
      "typescript": "^6"
    },
    "@typescript-eslint/eslint-plugin": {
      "typescript": "^6"
    },
    "@typescript-eslint/parser": {
      "typescript": "^6"
    }
  }
}
